    {
      "parameters": {
        "name": "create_transaction",
        "description": "Registra un nuevo movimiento financiero (gasto o ingreso) en el sistema.",
        "url": "http://backend:8000/api/v1/transactions",
        "method": "POST",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "{\n  \"whatsapp_id\": \"{{$parameter.whatsapp_id}}\",\n  \"amount\": {{$parameter.amount}},\n  \"type\": \"{{$parameter.type}}\",\n  \"description\": \"{{$parameter.description}}\",\n  \"category_name\": \"{{$parameter.category_name}}\",\n  \"raw_message\": \"{{$parameter.raw_message}}\"\n}",
        "outputFields": {
          "fields": [
            {
              "name": "id"
            },
            {
              "name": "amount"
            },
            {
              "name": "type"
            },
            {
              "name": "description"
            },
            {
              "name": "date"
            },
            {
              "name": "category"
            }
          ]
        }
      },
      "id": "a57bb8bf-1049-43c3-8f0a-a82f8a4cb135",
      "name": "create_transaction",
      "type": "@n8n/n8n-nodes-langchain.toolHttpRequest",
      "typeVersion": 1.1,
