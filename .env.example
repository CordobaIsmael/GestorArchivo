# --- BASE DE DATOS (PostgreSQL + pgvector) ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=finanzas_secure_pwd_2026
POSTGRES_DB=control_finanzas
POSTGRES_PORT=5435

# --- BACKEND (FastAPI) ---
# Usamos 'db' como host porque dentro de la red Docker Compose se resuelve por el nombre de servicio
DATABASE_URL=postgresql://postgres:finanzas_secure_pwd_2026@db:5432/control_finanzas
DATABASE_URL_LOCAL=postgresql://postgres:finanzas_secure_pwd_2026@127.0.0.1:5435/control_finanzas
PORT=8000

# --- INTELIGENCIA ARTIFICIAL (OpenAI) ---
# Completa con tu API Key de OpenAI para habilitar GPT-4o y Whisper
OPENAI_API_KEY=tu_openai_api_key_aqui

# --- N8N CONFIGURACIÓN ---
N8N_PORT=5678
N8N_ENCRYPTION_KEY=super_secret_encryption_key_for_n8n_security
# Deshabilitar registro inicial si se desea omitir formularios locales (opcional)
N8N_USER_MANAGEMENT_DISABLED=false

# --- EVOLUTION API (WhatsApp Gateway) ---
EVOLUTION_PORT=8080
EVOLUTION_API_KEY=global_api_token_evolution_api_2026
